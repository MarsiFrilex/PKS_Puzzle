fk8:q]|\n                    email = forms_result['contact_email']\n\n                    log_process(block_text='Присвоить значение переменной')\n\n                    log_process(window_log=True,block_text='Присвоить значение переменной')\n                    #Gjwp,T9x99#EYx*Dl84_\n                    course = forms_result['study_course']\n\n                    log_process(block_text='Присвоить значение переменной')\n\n                    log_process(window_log=True,block_text='Присвоить значение переменной')\n                    #nkuZ+v%I*h`^o-usfjtZ\n                    line_text = ''.join([str(x) for x in [fullname, ';', email, ';', course, f\"\\n\"]])\n\n                    log_process(block_text='Присвоить значение переменной')\n\n                    #qcdb9;{.o6uhNHk?_Y/]\n                    files_and_folders.append_txt_file(file_path=(files_and_folders.get_executable_path('internship_applications.txt',binary_path='FALSE',block_text=\"Относительный путь\",window_log=True, current_language=\"ru\")), data=line_text, encoding='utf-8',block_text=\"Дописать в файл\",window_log=True, current_language=\"ru\")\n\n                    log_process(window_log=True,block_text='Присвоить значение переменной')\n                    #Jw)C8!Qabg-Wv.ca-+DW\n                    accepted_count = accepted_count + 1\n\n                    log_process(block_text='Присвоить значение переменной')\n\n\n                log_process(block_text='Если – выполнить')\n\n\n            log_process(block_text='Цикл повторить n-раз')\n\n            #qbX49e8G[7_c3ZP8Cfy@\n            user_notice_2.user_notice((''.join([str(x2) for x2 in ['Принято заявок на стажировку', ':', accepted_count]])),None,block_text=\"Уведомление пользователя\",window_log=True, current_language=\"ru\")\n\n\n            logger.info(f'Завершение работы робота: {puzzle_logger_path}')\n            send_message_websocket(message_type=\"python_end\")\n        except Exception as error_puzzle:\n            logger.error(f'{puzzl