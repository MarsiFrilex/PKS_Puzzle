ne\"}}"],"scale":1},"editor":"# !/usr/bin/python \n# -*- coding: utf8 -*- \n# Puzzle RPA version: 2.3.0 \n# remote\nimport json\nimport sys\n\nsys.dont_write_bytecode = True\n\n# storage:\nfrom puzzle_logger import configure_logger, log_process, send_message_websocket\nfrom trace_utils import format_traceback\nfrom pathlib import Path\n\nimport add_to_dict\nimport files_and_folders\nimport read_file\nimport user_notice_2\n\n# generated\n# Опишите эту функцию…\ndef CheckBugSeverity(bug_dict):\n    log_process(window_log=True,block_text='Присвоить значение переменной')\n    #?19VG)O_`;|dsg3iw;M]\n    severity_value = bug_dict['severity']\n\n    log_process(block_text='Присвоить значение переменной')\n\n    log_process(window_log=True,block_text='Если – выполнить')\n    #O?=/h]D6N;4?4li%32$M\n    if severity_value == 'critical':\n        log_process(window_log=True,block_text='Присвоить значение переменной')\n        #G]`+.kHy#s(ddcMLAIIF\n        sms = 'Критическая'\n\n        log_process(block_text='Присвоить значение переменной')\n\n    else:\n        log_process(window_log=True,block_text='Присвоить значение переменной')\n        #]7Y30C.UkORAeWRpaY}V\n        sms = 'Не критическая'\n\n        log_process(block_text='Присвоить значение переменной')\n\n\n    log_process(block_text='Если – выполнить')\n\n    return sms\n\n\nlogger = configure_logger()\npuzzle_logger_path = Path(__file__).absolute()\nlogger.info(f'Старт робота: {puzzle_logger_path}')\n\nif __name__ == \"__main__\":\n    def main_llirik_159_proc():\n        try:\n            log_process(window_log=True,block_text='Присвоить значение переменной')\n            #!%zHL5Y50blWoOa1+0s7\n            bugs_list = read_file.read_json_file(None,(files_and_folders.get_executable_path('bugs_input.json',binary_path='TRUE',block_text=\"Относительный путь\",window_log=True, current_language=\"ru\")),block_text=\"Прочитать текст из json-файла\",window_log=True, current_language=\"ru\")\n\n            log_process(block_text='Присвоить значение переменной')\n\n            log_process(window_log=True,block_text='Присвоить значение переменной')\n            #q:vB?Id{H2q(Le;iiPzr\n            severity_check_list = []\n\n            log_process(block_text='Присвоить значение переменной')\n\n            log_process(window_log=True,block_text='Цикл для каждого элемента')\n            #VQV=`JC!A7G}lU]GEXEo\n            for j in bugs_list:\n                log_process(window_log=True,block_text='Присвоить значение переменной')\n                #t=.^uF|k5{9}u6w?Zr.,\n                severity_status = CheckBugSeverity(j)\n\n                log_process(block_text='Присвоить значение переменной')\n\n                log_process(window_log=True,block_text='Присвоить значение переменной')\n                #U0?af,]mPV_RBkal{0L9\n                result_record = {}\n\n                log_process(block_text='Присвоить значение переменной')\n\n                #E:k3RC_Gbaox68F:lOF.\n                add_to_dict.add_to_dict(result_record,'bug_id',(j['bug_id']),block_text=\"Добавить элемент в словарь\",window_log=True, current_language=\"ru\")\n\n                #AHQ$s)Wm7mxwU~rP9o7O\n                add_to_dict.add_to_dict(result_record,'severity_status',severity_status,block_text=\"Добавить элемент в словарь\",window_log=True, current_language=\"ru\")\n\n                log_process(window_log=True,block_text='Добавить элемент в список')\n                #qJ{#*HzH]LNY@%JlQOlS\n                severity_check_list.append(result_record)\n\n                log_process(block_text='Добавить элемент в список')\n\n\n            log_process(block_text='Цикл для каждого элемента')\n\n            #-_FpQE|b2cRDq}e[-z-^\n            files_and_folders.create_json((files_and_folders.get_executable_path('severity_check.json',binary_path='TRUE',block_text=\"Относительный путь\",window_log=True, current_language=\"ru\")),'utf-8',severity_check_list,block_text=\"Создать json-файл\",window_log=True, current_language=\"ru\")\n\n            #Ammj+_*C-/4F{+zEs`}.\n            user_notice_2.user_notice(severity_check_list,None,block_text=\"Уведомление пользователя\",window_log=True, current_language=\"ru\")\n\n\n            logger.info(f'Завершение работы робота: {puzzle_logger_path}')\n            send_message_websocket(message_type=\"python_end\")\n        except Exception as error_puzzle:\n            logger.error(f'{puzzle_logger_path} ' + f'Ошибка: {error_puzzle}')\n            error_puzzle_format=format_traceback(error_puzzle)\n            send_message_websocket(message_type=\"python_error\", message=error_puzzle_format)\n            raise Exception(error_puzzle)\n    main_llirik_159_proc()","pId":"llirik_159"}
